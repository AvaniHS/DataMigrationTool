# Copy to .env and adjust paths for local CSV (local_path) connections.
# Paths are resolved on the machine running the API (uvicorn), not the browser.

# JSON array of directories the API may read for local_path CSV files.
# Default if unset: ["data"] relative to the API working directory.
CONFIG_API_FILE_ROOTS=["data","D:/Projects/TL/Projects/DataMigrationTool/docs"]

# Optional overrides
# CONFIG_API_SCRIPT_GENERATOR_URL=http://localhost:8001
# CONFIG_API_VALIDATION_TIMEOUT_SECONDS=30
# CONFIG_API_MAX_UPLOAD_MB=500
# CONFIG_API_STAGING_TTL_DAYS=30
